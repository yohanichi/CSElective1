{
  "version": 2,
  "framework": "laravel",
  "functions": {
    "api/index.php": {
      "runtime": "php:8.2",
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "public"
}
